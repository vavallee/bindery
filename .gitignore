# Binaries
/bindery
*.exe
*.dll
*.so
*.dylib

# Go
/vendor/
*.test
coverage.out
coverage.html

# codecov-action@v5 downloads these into the checkout on Linux runners.
# Without this ignore, GoReleaser on tag pushes aborts with "git is in a
# dirty state" because the codecov uploader runs earlier in the same job.
/codecov
/codecov.SHA256SUM
/codecov.SHA256SUM.sig

# Frontend
web/node_modules/
web/coverage/
web/dist/
web/.vite/
web/tsconfig.tsbuildinfo

# Embedded frontend build artifacts (rebuilt by CI/Makefile).
# Glob covers all generated files; .gitkeep is excluded so the empty-dir
# placeholder stays tracked and goreleaser sees a clean working tree.
internal/webui/dist/*
!internal/webui/dist/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Config / runtime
*.db
*.db-shm
*.db-wal
/config/
/data/

# Docker
.docker/

# Environment
.env
.env.local
.env.*.local
.claude/
.codex/

# Embedded Dolt runtime data (auto-generated by GT polecat tooling)
embeddeddolt/
